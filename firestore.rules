rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidEnrollment(data) {
      return data.fullName is string && data.fullName.size() > 2 && data.fullName.size() < 100 &&
             data.phone is string && data.phone.size() >= 11 && data.phone.size() <= 14 &&
             data.paymentMethod in ['bkash', 'nagad', 'upay', 'bank'] &&
             data.transactionId is string && data.transactionId.size() > 5 &&
             data.senderNumber is string &&
             data.amount is number && data.amount >= 1000;
    }

    match /enrollments/{enrollmentId} {
      // Anyone can create an enrollment (public registration)
      allow create: if isValidEnrollment(request.resource.data);
      
      // Only authenticated admins can read/update all enrollments
      allow read, update, delete: if isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "sakibulislamsbmc@gmail.com");
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId);
      allow write: if false; // Only manageable via console for now
    }
  }
}
